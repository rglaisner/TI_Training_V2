# Copy to .env or .env.local (backend loads both; .env.local overrides .env).
PORT=4000
HOST=0.0.0.0

# Path to the service account JSON (Firebase → Project settings → Service accounts → Generate new private key).
# On Windows use forward slashes OR double backslashes — a single \t inside a path is read as a TAB and breaks the path.
# Example: GOOGLE_APPLICATION_CREDENTIALS=C:/secrets/tic-firebase-admin.json
# GOOGLE_APPLICATION_CREDENTIALS=

# Local dev without Firebase sign-in (pair with frontend NEXT_PUBLIC_USE_TEST_AUTH=true).
# USE_TEST_AUTH=true
# USE_IN_MEMORY_PERSISTENCE=true
