{
  "name": "@ti-training/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "set-user-claims": "tsx scripts/setUserClaims.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external --alias:@ti-training/shared=../../packages/shared/src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"no lint config yet\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@ti-training/shared": "0.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "firebase-admin": "^13.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.1"
  }
}
